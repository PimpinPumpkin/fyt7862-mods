<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:gravity="fill_horizontal|center" android:id="@android:id/background">
        <shape android:shape="rectangle">
            <size android:height="10.0px" />
            <corners android:radius="5.0px" />
            <solid android:color="#c0bdbd" />
        </shape>
    </item>
    <item android:gravity="fill_horizontal|center" android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <size android:height="10.0px" />
                <corners android:radius="5.0px" />
                <gradient android:startColor="#FF7176FA" android:endColor="#FF6CDDFA" android:angle="0.0" />
            </shape>
        </clip>
    </item>
</layer-list>
